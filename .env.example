# Copy to .env.local and fill in. Every value is optional — with none set,
# the app runs in demo mode with seeded in-memory data.

# --- Database (Neon Postgres) ---
# Without this the app uses the built-in demo dataset.
# Apply db/schema.sql then db/seed.sql once provisioned.
DATABASE_URL=

# --- Auth ---
# Signs the session JWTs. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

# Staff login for the admin dashboard.
# Defaults to admin / caravan2026 when unset (demo only — always set these in production).
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Stripe (future) ---
# Leave blank to keep the store in enquiry mode; orders are recorded without payment.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
